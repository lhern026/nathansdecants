<section class="product-story" aria-label="Product Story">
  {%- comment -%} ━━━ SCENT DATA ENGINE ━━━ {%- endcomment -%}
  {%- assign handle = product.handle -%}
  
  {%- comment -%} Default Values {%- endcomment -%}
  {%- assign top_note_name = "Citrus Accord" -%}
  {%- assign top_note_desc = "A bright, luminous opening that awakens the senses." -%}
  {%- assign heart_note_name = "Floral Heart" -%}
  {%- assign heart_note_desc = "The emotional core of the fragrance, blooming with depth." -%}
  {%- assign base_note_name = "Amber & Woods" -%}
  {%- assign base_note_desc = "A long-lasting foundation that lingers on the skin." -%}
  {%- assign story_headline = "Every scent tells a story. This is ours." -%}

  {%- case handle -%}
    {%- when 'absolute-aphrodisiac' -%}
      {%- assign top_note_name = "White Flowers" -%}
      {%- assign top_note_desc = "A delicate, ethereal opening of jasmine and lily." -%}
      {%- assign heart_note_name = "Amber & Vanilla" -%}
      {%- assign heart_note_desc = "The signature warmth that creates an irresistible pull." -%}
      {%- assign base_note_name = "Musk & Castoreum" -%}
      {%- assign base_note_desc = "Animalic depth that settles into a second-skin finish." -%}
      {%- assign story_headline = "A primal invitation to the senses." -%}
    
    {%- when 'atomic-rose' -%}
      {%- assign top_note_name = "Italian Bergamot" -%}
      {%- assign top_note_desc = "Crisp, bright citrus that sets the stage for the explosion." -%}
      {%- assign heart_note_name = "Bulgarian Rose" -%}
      {%- assign heart_note_desc = "A powerful, multi-faceted floral heart that demands attention." -%}
      {%- assign base_note_name = "Madagascar Vanilla" -%}
      {%- assign base_note_desc = "Creamy sweetness that anchors the rose in pure luxury." -%}
      {%- assign story_headline = "An olfactory explosion of pure energy." -%}

    {%- when 'babycat' -%}
      {%- assign top_note_name = "Pink Pepper" -%}
      {%- assign top_note_desc = "A spicy, electric opening that tingles the senses." -%}
      {%- assign heart_note_name = "Saffron & Elemi" -%}
      {%- assign heart_note_desc = "Resinous and exotic, creating a sophisticated warmth." -%}
      {%- assign base_note_name = "Suede & Vanilla" -%}
      {%- assign base_note_desc = "The iconic leathery finish of YSL's masterpiece." -%}
      {%- assign story_headline = "The sophisticated purr of couture." -%}

    {%- when 'another-13' -%}
      {%- assign top_note_name = "Ambroxan" -%}
      {%- assign top_note_desc = "The synthetic heart that creates a clean, metallic buzz." -%}
      {%- assign heart_note_name = "Jasmine Petals" -%}
      {%- assign heart_note_desc = "A subtle floral hum that adds crystalline clarity." -%}
      {%- assign base_note_name = "Moss & Musk" -%}
      {%- assign base_note_desc = "An earthy, skin-like finish that lasts for days." -%}
      {%- assign story_headline = "An addictive, crystalline addiction." -%}

    {%- when 'noir-29' -%}
      {%- assign top_note_name = "Fig & Bay Leaf" -%}
      {%- assign top_note_desc = "A fresh, green opening that feels like a crisp morning." -%}
      {%- assign heart_note_name = "Cedar & Vetiver" -%}
      {%- assign heart_note_desc = "Strong, masculine woods that provide a solid structure." -%}
      {%- assign base_note_name = "Black Tea & Tobacco" -%}
      {%- assign base_note_desc = "A smoky, sophisticated dry down with deep complexity." -%}
      {%- assign story_headline = "An ode to the noble leaf." -%}

    {%- when 'blue-talisman-edp' -%}
      {%- assign top_note_name = "Ginger & Mandarin" -%}
      {%- assign top_note_desc = "A zesty, sparkling introduction full of light." -%}
      {%- assign heart_note_name = "Orange Blossom" -%}
      {%- assign heart_note_desc = "Soft, white florals that bring a Mediterranean breeze." -%}
      {%- assign base_note_name = "Akigalawood" -%}
      {%- assign base_note_desc = "A modern, vibrant woody finish with immense trail." -%}
      {%- assign story_headline = "A celestial charm for the modern era." -%}

    {%- when 'adonis-awakens' -%}
      {%- assign top_note_name = "Grapefruit & Bergamot" -%}
      {%- assign top_note_desc = "A burst of sunshine to start the morning." -%}
      {%- assign heart_note_name = "Raspberry & Rose" -%}
      {%- assign heart_note_desc = "Sweet, jammy florals that feel lush and romantic." -%}
      {%- assign base_note_name = "Vanilla & Chestnut" -%}
      {%- assign base_note_desc = "A gourmand, nutty finish that feels warm and cozy." -%}
      {%- assign story_headline = "The awakening of a Greek myth." -%}
  {%- endcase -%}

  {%- comment -%} ━━━ CHAPTER 1 — The Opening Statement ━━━ {%- endcomment -%}
  <div class="story__chapter story__opening">
    <div class="container">
      <div class="story__opening-layout">
        <div class="story__opening-text reveal">
          <span class="story__eyebrow">{{ section.settings.chapter_1_eyebrow }}</span>
          <h2 class="story__headline">{{ story_headline }}</h2>
        </div>
        <div class="story__opening-body reveal">
          <p class="story__prose">{{ section.settings.chapter_1_body }}</p>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ━━━ CHAPTER 2 — The Scent Notes Breakdown ━━━ {%- endcomment -%}
  <div class="story__chapter story__notes">
    <div class="container">
      <div class="story__notes-header reveal">
        <span class="story__eyebrow">{{ section.settings.notes_eyebrow }}</span>
        <h2 class="story__section-title">{{ section.settings.notes_title }}</h2>
      </div>

      <div class="story__notes-grid">
        {%- comment -%} Top Note {%- endcomment -%}
        <div class="story__note-card reveal">
          <div class="story__note-shell">
            <div class="story__note-inner">
              <span class="story__note-tier">Top Note</span>
              <h3 class="story__note-name">{{ top_note_name }}</h3>
              <p class="story__note-description">{{ top_note_desc }}</p>
            </div>
          </div>
        </div>

        {%- comment -%} Heart Note {%- endcomment -%}
        <div class="story__note-card reveal">
          <div class="story__note-shell">
            <div class="story__note-inner">
              <span class="story__note-tier">Heart Note</span>
              <h3 class="story__note-name">{{ heart_note_name }}</h3>
              <p class="story__note-description">{{ heart_note_desc }}</p>
            </div>
          </div>
        </div>

        {%- comment -%} Base Note {%- endcomment -%}
        <div class="story__note-card reveal">
          <div class="story__note-shell">
            <div class="story__note-inner">
              <span class="story__note-tier">Base Note</span>
              <h3 class="story__note-name">{{ base_note_name }}</h3>
              <p class="story__note-description">{{ base_note_desc }}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ━━━ CHAPTER 3 — The Narrative Pull Quote ━━━ {%- endcomment -%}
  <div class="story__chapter story__pullquote-section">
    <div class="container">
      <div class="story__pullquote-wrap reveal">
        <div class="story__pullquote-line"></div>
        <blockquote class="story__pullquote">
          {{ section.settings.pullquote }}
        </blockquote>
        <div class="story__pullquote-line"></div>
        <cite class="story__pullquote-cite">{{ section.settings.pullquote_cite }}</cite>
      </div>
    </div>
  </div>

  {%- comment -%} ━━━ CHAPTER 4 — The Craft Process ━━━ {%- endcomment -%}
  <div class="story__chapter story__craft">
    <div class="container">
      <div class="story__craft-layout">
        <div class="story__craft-visual reveal">
          <div class="story__craft-shell">
            <div class="story__craft-inner">
              {%- if section.settings.craft_image -%}
                <img 
                  src="{{ section.settings.craft_image | img_url: 'master' }}" 
                  alt="{{ section.settings.craft_image.alt | default: 'The craft of decanting' }}" 
                  loading="lazy"
                  class="story__craft-img"
                >
              {%- else -%}
                <div class="story__craft-placeholder">
                  <span>The Craft</span>
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>
        <div class="story__craft-text reveal">
          <span class="story__eyebrow">{{ section.settings.craft_eyebrow }}</span>
          <h2 class="story__section-title">{{ section.settings.craft_headline }}</h2>
          <p class="story__prose">{{ section.settings.craft_body }}</p>
          <div class="story__craft-details">
            {%- for block in section.blocks -%}
              {%- if block.type == 'craft_detail' -%}
                <div class="story__craft-detail" {{ block.shopify_attributes }}>
                  <span class="story__craft-detail-num">{{ block.settings.number }}</span>
                  <span class="story__craft-detail-label">{{ block.settings.label }}</span>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ━━━ CHAPTER 5 — The Final CTA ━━━ {%- endcomment -%}
  <div class="story__chapter story__cta-section">
    <div class="container">
      <div class="story__cta-wrap reveal">
        <span class="story__eyebrow">{{ section.settings.cta_eyebrow }}</span>
        <h2 class="story__cta-headline">{{ section.settings.cta_headline }}</h2>
        <a href="/collections/all" class="btn btn--outline">
          <span>{{ section.settings.cta_button_text }}</span>
          <span class="btn__icon">→</span>
        </a>
      </div>
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Product Story",
  "settings": [
    {
      "type": "header",
      "content": "Chapter 1 — Opening"
    },
    {
      "type": "text",
      "id": "chapter_1_eyebrow",
      "label": "Eyebrow",
      "default": "The Narrative"
    },
    {
      "type": "textarea",
      "id": "chapter_1_headline",
      "label": "Headline",
      "default": "Every scent tells a story. This is ours."
    },
    {
      "type": "textarea",
      "id": "chapter_1_body",
      "label": "Body Text",
      "default": "We believe fragrance is the most intimate form of self-expression. Each decant is a chapter — poured by hand, sealed with intention, and delivered as an invitation to discover something extraordinary."
    },
    {
      "type": "header",
      "content": "Chapter 2 — Scent Notes"
    },
    {
      "type": "text",
      "id": "notes_eyebrow",
      "label": "Eyebrow",
      "default": "Olfactory Architecture"
    },
    {
      "type": "text",
      "id": "notes_title",
      "label": "Title",
      "default": "The Composition"
    },
    {
      "type": "header",
      "content": "Chapter 3 — Pull Quote"
    },
    {
      "type": "textarea",
      "id": "pullquote",
      "label": "Quote",
      "default": "Perfume is the art that makes memory speak."
    },
    {
      "type": "text",
      "id": "pullquote_cite",
      "label": "Citation",
      "default": "— Francis Kurkdjian"
    },
    {
      "type": "header",
      "content": "Chapter 4 — The Craft"
    },
    {
      "type": "text",
      "id": "craft_eyebrow",
      "label": "Eyebrow",
      "default": "The Process"
    },
    {
      "type": "text",
      "id": "craft_headline",
      "label": "Headline",
      "default": "Poured by Hand"
    },
    {
      "type": "textarea",
      "id": "craft_body",
      "label": "Body",
      "default": "Every decant is measured with precision, poured in small batches, and sealed in pharmaceutical-grade glass. We treat each vial like a handwritten letter — because it is one."
    },
    {
      "type": "image_picker",
      "id": "craft_image",
      "label": "Craft Image"
    },
    {
      "type": "header",
      "content": "Chapter 5 — Call to Action"
    },
    {
      "type": "text",
      "id": "cta_eyebrow",
      "label": "Eyebrow",
      "default": "Begin Your Journey"
    },
    {
      "type": "textarea",
      "id": "cta_headline",
      "label": "Headline",
      "default": "Find Your Signature"
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "Button Text",
      "default": "Explore the Collection"
    }
  ],
  "blocks": [
    {
      "type": "note",
      "name": "Scent Note",
      "settings": [
        {
          "type": "text",
          "id": "tier",
          "label": "Tier (e.g. Top, Heart, Base)",
          "default": "Top Note"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Note Name",
          "default": "Bergamot"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "A bright, sun-drenched citrus that opens the composition with a burst of luminous energy."
        }
      ]
    },
    {
      "type": "craft_detail",
      "name": "Craft Detail",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number / Stat",
          "default": "100%"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Authentic"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Story",
      "blocks": [
        {
          "type": "note",
          "settings": {
            "tier": "Top Note",
            "name": "Bergamot",
            "description": "A bright, sun-drenched citrus that opens the composition with a burst of luminous energy."
          }
        },
        {
          "type": "note",
          "settings": {
            "tier": "Heart Note",
            "name": "Turkish Rose",
            "description": "Velvety and intoxicating, the rose anchors the fragrance with romantic depth and emotional warmth."
          }
        },
        {
          "type": "note",
          "settings": {
            "tier": "Base Note",
            "name": "Oud & Amber",
            "description": "A smoky, resinous foundation that lingers on the skin for hours — the memory that stays."
          }
        },
        {
          "type": "craft_detail",
          "settings": {
            "number": "100%",
            "label": "Authentic"
          }
        },
        {
          "type": "craft_detail",
          "settings": {
            "number": "1–3",
            "label": "Days to Ship"
          }
        },
        {
          "type": "craft_detail",
          "settings": {
            "number": "3–10ml",
            "label": "Discovery Sizes"
          }
        }
      ]
    }
  ]
}
{% endschema %}
