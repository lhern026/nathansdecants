<section class="product-story" aria-label="Product Story">

  {%- comment -%} ━━━ CHAPTER 1 — The Opening Statement ━━━ {%- endcomment -%}
  <div class="story__chapter story__opening">
    <div class="container">
      <div class="story__opening-layout">
        <div class="story__opening-text reveal">
          <span class="story__eyebrow">{{ section.settings.chapter_1_eyebrow }}</span>
          <h2 class="story__headline">{{ section.settings.chapter_1_headline }}</h2>
        </div>
        <div class="story__opening-body reveal">
          <p class="story__prose">{{ section.settings.chapter_1_body }}</p>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ━━━ CHAPTER 2 — The Scent Notes Breakdown ━━━ {%- endcomment -%}
  <div class="story__chapter story__notes">
    <div class="container">
      <div class="story__notes-header reveal">
        <span class="story__eyebrow">{{ section.settings.notes_eyebrow }}</span>
        <h2 class="story__section-title">{{ section.settings.notes_title }}</h2>
      </div>

      <div class="story__notes-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'note' -%}
            <div class="story__note-card reveal" {{ block.shopify_attributes }}>
              <div class="story__note-shell">
                <div class="story__note-inner">
                  <span class="story__note-tier">{{ block.settings.tier }}</span>
                  <h3 class="story__note-name">{{ block.settings.name }}</h3>
                  <p class="story__note-description">{{ block.settings.description }}</p>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} ━━━ CHAPTER 3 — The Narrative Pull Quote ━━━ {%- endcomment -%}
  <div class="story__chapter story__pullquote-section">
    <div class="container">
      <div class="story__pullquote-wrap reveal">
        <div class="story__pullquote-line"></div>
        <blockquote class="story__pullquote">
          {{ section.settings.pullquote }}
        </blockquote>
        <div class="story__pullquote-line"></div>
        <cite class="story__pullquote-cite">{{ section.settings.pullquote_cite }}</cite>
      </div>
    </div>
  </div>

  {%- comment -%} ━━━ CHAPTER 4 — The Craft Process ━━━ {%- endcomment -%}
  <div class="story__chapter story__craft">
    <div class="container">
      <div class="story__craft-layout">
        <div class="story__craft-visual reveal">
          <div class="story__craft-shell">
            <div class="story__craft-inner">
              {%- if section.settings.craft_image -%}
                <img 
                  src="{{ section.settings.craft_image | img_url: 'master' }}" 
                  alt="{{ section.settings.craft_image.alt | default: 'The craft of decanting' }}" 
                  loading="lazy"
                  class="story__craft-img"
                >
              {%- else -%}
                <div class="story__craft-placeholder">
                  <span>The Craft</span>
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>
        <div class="story__craft-text reveal">
          <span class="story__eyebrow">{{ section.settings.craft_eyebrow }}</span>
          <h2 class="story__section-title">{{ section.settings.craft_headline }}</h2>
          <p class="story__prose">{{ section.settings.craft_body }}</p>
          <div class="story__craft-details">
            {%- for block in section.blocks -%}
              {%- if block.type == 'craft_detail' -%}
                <div class="story__craft-detail" {{ block.shopify_attributes }}>
                  <span class="story__craft-detail-num">{{ block.settings.number }}</span>
                  <span class="story__craft-detail-label">{{ block.settings.label }}</span>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ━━━ CHAPTER 5 — The Final CTA ━━━ {%- endcomment -%}
  <div class="story__chapter story__cta-section">
    <div class="container">
      <div class="story__cta-wrap reveal">
        <span class="story__eyebrow">{{ section.settings.cta_eyebrow }}</span>
        <h2 class="story__cta-headline">{{ section.settings.cta_headline }}</h2>
        <a href="/collections/all" class="btn btn--outline">
          <span>{{ section.settings.cta_button_text }}</span>
          <span class="btn__icon">→</span>
        </a>
      </div>
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Product Story",
  "settings": [
    {
      "type": "header",
      "content": "Chapter 1 — Opening"
    },
    {
      "type": "text",
      "id": "chapter_1_eyebrow",
      "label": "Eyebrow",
      "default": "The Narrative"
    },
    {
      "type": "textarea",
      "id": "chapter_1_headline",
      "label": "Headline",
      "default": "Every scent tells a story. This is ours."
    },
    {
      "type": "textarea",
      "id": "chapter_1_body",
      "label": "Body Text",
      "default": "We believe fragrance is the most intimate form of self-expression. Each decant is a chapter — poured by hand, sealed with intention, and delivered as an invitation to discover something extraordinary."
    },
    {
      "type": "header",
      "content": "Chapter 2 — Scent Notes"
    },
    {
      "type": "text",
      "id": "notes_eyebrow",
      "label": "Eyebrow",
      "default": "Olfactory Architecture"
    },
    {
      "type": "text",
      "id": "notes_title",
      "label": "Title",
      "default": "The Composition"
    },
    {
      "type": "header",
      "content": "Chapter 3 — Pull Quote"
    },
    {
      "type": "textarea",
      "id": "pullquote",
      "label": "Quote",
      "default": "Perfume is the art that makes memory speak."
    },
    {
      "type": "text",
      "id": "pullquote_cite",
      "label": "Citation",
      "default": "— Francis Kurkdjian"
    },
    {
      "type": "header",
      "content": "Chapter 4 — The Craft"
    },
    {
      "type": "text",
      "id": "craft_eyebrow",
      "label": "Eyebrow",
      "default": "The Process"
    },
    {
      "type": "text",
      "id": "craft_headline",
      "label": "Headline",
      "default": "Poured by Hand"
    },
    {
      "type": "textarea",
      "id": "craft_body",
      "label": "Body",
      "default": "Every decant is measured with precision, poured in small batches, and sealed in pharmaceutical-grade glass. We treat each vial like a handwritten letter — because it is one."
    },
    {
      "type": "image_picker",
      "id": "craft_image",
      "label": "Craft Image"
    },
    {
      "type": "header",
      "content": "Chapter 5 — Call to Action"
    },
    {
      "type": "text",
      "id": "cta_eyebrow",
      "label": "Eyebrow",
      "default": "Begin Your Journey"
    },
    {
      "type": "textarea",
      "id": "cta_headline",
      "label": "Headline",
      "default": "Find Your Signature"
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "Button Text",
      "default": "Explore the Collection"
    }
  ],
  "blocks": [
    {
      "type": "note",
      "name": "Scent Note",
      "settings": [
        {
          "type": "text",
          "id": "tier",
          "label": "Tier (e.g. Top, Heart, Base)",
          "default": "Top Note"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Note Name",
          "default": "Bergamot"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "A bright, sun-drenched citrus that opens the composition with a burst of luminous energy."
        }
      ]
    },
    {
      "type": "craft_detail",
      "name": "Craft Detail",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number / Stat",
          "default": "100%"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Authentic"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Story",
      "blocks": [
        {
          "type": "note",
          "settings": {
            "tier": "Top Note",
            "name": "Bergamot",
            "description": "A bright, sun-drenched citrus that opens the composition with a burst of luminous energy."
          }
        },
        {
          "type": "note",
          "settings": {
            "tier": "Heart Note",
            "name": "Turkish Rose",
