<section class="section editorial-craft">
  <div class="container">
    <div class="editorial-craft__layout">
      
      {%- comment -%} Left: High-End Image with Double-Bezel {%- endcomment -%}
      <div class="editorial-craft__media reveal">
        <div class="editorial-craft__shell">
          <div class="editorial-craft__inner">
            {%- if section.settings.image -%}
              <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.image.alt | default: 'The decanting craft' }}" loading="lazy">
            {%- else -%}
              <div class="editorial-craft__placeholder">
                <span>The Process</span>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>

      {%- comment -%} Right: Massive Typography & Story {%- endcomment -%}
      <div class="editorial-craft__content reveal" style="transition-delay: 200ms">
        <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 class="editorial-craft__title">{{ section.settings.title }}</h2>
        <div class="editorial-craft__prose">
          {{ section.settings.text }}
        </div>
        
        <div class="editorial-craft__stats">
          <div class="editorial-craft__stat">
            <span class="editorial-craft__stat-value">100%</span>
            <span class="editorial-craft__stat-label">Authentic Juice</span>
          </div>
          <div class="editorial-craft__stat">
            <span class="editorial-craft__stat-value">0ml</span>
            <span class="editorial-craft__stat-label">Contamination</span>
          </div>
        </div>

        {%- if section.settings.button_text != blank -%}
          <a href="{{ section.settings.button_link | default: '/pages/about' }}" class="btn btn--outline editorial-craft__btn">
            <span>{{ section.settings.button_text }}</span>
            <span class="btn__icon">→</span>
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "The Craft (Editorial)",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Process Image (e.g., Medical Syringe or Glass Vial)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Authenticity Guarantee"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Heading",
      "default": "The Art of the Pour."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body Text",
      "default": "<p>Every decant is extracted using sterile, medical-grade syringes directly from 100% authentic retail bottles. No funnels. No splashing. Pure, uncontaminated fragrance delivered exactly as the master perfumer intended.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Learn Our Process"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "The Craft (Editorial)"
    }
  ]
}
{% endschema %}
