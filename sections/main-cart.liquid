<section class="cart-page">
  <div class="container">
    <h1 class="cart-title reveal">Your Edit</h1>

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" id="CartForm" novalidate>
        
        <div class="cart-items">
          {%- for item in cart.items -%}
            <div class="cart-item reveal" style="transition-delay: {{ forloop.index | times: 100 }}ms;">
              <div class="cart-item__image">
                {%- if item.image -%}
                   <img src="{{ item.image | img_url: '400x' }}" alt="{{ item.title | escape }}" loading="lazy" style="width:100%;height:100%;object-fit:contain;">
                {%- else -%}
                   <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--color-bg-elevated);border-radius:var(--radius-md);">
                     <span style="font-family:var(--font-heading);font-style:italic;color:var(--color-text-muted);font-size:0.8rem;text-align:center;">{{ item.title }}</span>
                   </div>
                {%- endif -%}
              </div>
              
              <div class="cart-item__details">
                <h3 class="cart-item__title"><a href="{{ item.url }}">{{ item.product.title }}</a></h3>
                {%- unless item.product.has_only_default_variant -%}
                  <div class="cart-item__variant">{{ item.variant.title }}</div>
                {%- endunless -%}
                <a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0" class="cart-item__remove">Remove</a>
              </div>
              
              <div class="cart-item__meta">
                <div class="cart-item__price">{{ item.final_line_price | money }}</div>
                <div class="cart-qty-control">
                  <button type="button" class="cart-qty-btn js-qty-minus" aria-label="Decrease quantity">−</button>
                  <input type="number" name="updates[]" id="updates_{{ item.key }}" value="{{ item.quantity }}" min="0" class="cart-qty-input" aria-label="Quantity for {{ item.title | escape }}">
                  <button type="button" class="cart-qty-btn js-qty-plus" aria-label="Increase quantity">+</button>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div class="cart-summary reveal" style="transition-delay: 500ms;">
          <div class="cart-summary__row">
            <span class="cart-summary__label">Subtotal</span>
            <span class="cart-summary__total js-cart-subtotal">{{ cart.total_price | money }}</span>
          </div>
          <p class="cart-summary__note">Taxes and shipping calculated at checkout.</p>
          
          <button type="submit" name="checkout" class="btn btn--solid btn--full">
            <span>Proceed to Checkout</span>
            <span class="btn__icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
            </span>
          </button>
        </div>

      </form>
    {%- else -%}
      <div class="cart-empty reveal">
        <p>Your edit is currently empty.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn">
          <span>Continue Selection</span>
          <span class="btn__icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
          </span>
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
