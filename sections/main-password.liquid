<section class="page-centered">
  <div class="header-logo reveal" style="margin-bottom: 3rem; font-size: 2rem;">{{ shop.name }}</div>
  <span class="section-eyebrow reveal" style="transition-delay: 100ms;">Opening Soon</span>
  
  <div class="reveal" style="width: 100%; display: flex; justify-content: center; transition-delay: 200ms;">
    {% form 'storefront_password' %}
      {{ form.errors | default_errors }}
      <input type="password" name="password" placeholder="Enter store password" class="password-input" aria-label="Password">
      <button type="submit" class="btn btn--solid btn--full">
        <span>Enter</span>
      </button>
    {% endform %}
  </div>
  
  <p class="reveal" style="margin-top: 3rem; font-size: 0.7rem; opacity: 0.4; transition-delay: 300ms;">
    Store owner? <a href="/admin" style="text-decoration: underline;">Log in here</a>
  </p>
</section>

{% schema %}
{
  "name": "Password Page",
  "settings": []
}
{% endschema %}
