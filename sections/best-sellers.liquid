<section class="section best-sellers">
  <div class="container best-sellers__container">
    
    {%- comment -%} Left: Editorial Typography {%- endcomment -%}
    <div class="best-sellers__editorial reveal">
      <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="section-title">{{ section.settings.title }}</h2>
      <p class="best-sellers__prose">{{ section.settings.text }}</p>
      
      {%- if section.settings.button_text != blank -%}
        <div style="margin-top: 3rem;">
          <a href="{{ section.settings.collection.url | default: '/collections/all' }}" class="btn btn--outline">
            {{ section.settings.button_text }}
            <span class="btn__icon">→</span>
          </a>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Right: Horizontal Scroll Track {%- endcomment -%}
    <div class="best-sellers__track-wrap reveal" style="transition-delay: 200ms">
      <div class="best-sellers__track">
        {%- assign collection = collections[section.settings.collection] -%}
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          <div class="product-card best-sellers__card">
            <a href="{{ product.url }}" class="product-card__link" aria-label="{{ product.title | escape }}">
              <div class="product-card__shell">
                <div class="product-card__inner">
                  
                  {%- if product.featured_image -%}
                    <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.title | escape }}" loading="lazy">
                  {%- else -%}
                    <div class="product-card__image-fallback">
                      <span>{{ product.title }}</span>
                    </div>
                  {%- endif -%}
                  
                  <div class="best-sellers__card-info">
                    <span class="best-sellers__card-vendor">{{ product.vendor | default: 'Fragrance House' }}</span>
                    <h3 class="best-sellers__card-title">{{ product.title }}</h3>
                    <div class="best-sellers__card-price">
                      {%- if product.compare_at_price > product.price -%}
                        <s>{{ product.compare_at_price | money }}</s>
                      {%- endif -%}
                      From {{ product.price | money | default: '$25.00' }}
                    </div>
                  </div>

                </div>
              </div>
            </a>
          </div>
        {%- else -%}
          {%- comment -%} Placeholder state {%- endcomment -%}
          {%- for i in (1..4) -%}
            <div class="product-card best-sellers__card">
              <div class="product-card__shell">
                <div class="product-card__inner">
                  <div class="product-card__image-fallback">
                    <span>Top Seller {{ i }}</span>
                  </div>
                  <div class="best-sellers__card-info">
                    <span class="best-sellers__card-vendor">Fragrance House</span>
                    <h3 class="best-sellers__card-title">Signature Scent</h3>
                    <div class="best-sellers__card-price">From $29.00</div>
                  </div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Best Sellers (Editorial)",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Most Requested"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "The Best Sellers."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Philosophy Text",
      "default": "The fragrances currently dominating TikTok. Proven compliment getters, available in discovery-sized decants."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View All Best Sellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Best Sellers (Editorial)"
    }
  ]
}
{% endschema %}
