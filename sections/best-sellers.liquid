<section class="section best-sellers">
  <div class="container">

    {%- comment -%} Header {%- endcomment -%}
    <div class="best-sellers__header reveal">
      <div class="best-sellers__header-left">
        <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 class="section-title">{{ section.settings.title }}</h2>
      </div>
      <div class="best-sellers__header-right">
        <p class="best-sellers__prose">{{ section.settings.text }}</p>
        {%- if section.settings.button_text != blank -%}
          <a href="{{ section.settings.collection.url | default: '/collections/all' }}" class="btn btn--outline" style="margin-top: 2rem;">
            {{ section.settings.button_text }}
            <span class="btn__icon">→</span>
          </a>
        {%- endif -%}
      </div>
    </div>

  </div>

  {%- comment -%} Full-Bleed Horizontal Scroll {%- endcomment -%}
  <div class="best-sellers__scroll reveal" style="transition-delay: 200ms">
    <div class="best-sellers__track">
      {%- assign collection = collections[section.settings.collection] -%}
      {%- for product in collection.products limit: section.settings.products_to_show -%}
        <a href="{{ product.url }}" class="best-sellers__item" aria-label="{{ product.title | escape }}">
          
          {%- comment -%} Ranking Number {%- endcomment -%}
          <span class="best-sellers__rank">{{ forloop.index | prepend: '00' | slice: -2, 2 }}</span>

          {%- comment -%} Image — Dark Background Container {%- endcomment -%}
          <div class="best-sellers__image">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.title | escape }}" loading="lazy">
            {%- else -%}
              <div class="best-sellers__image-fallback"></div>
            {%- endif -%}
          </div>

          {%- comment -%} Info {%- endcomment -%}
          <div class="best-sellers__info">
            <span class="best-sellers__vendor">{{ product.vendor }}</span>
            <h3 class="best-sellers__name">{{ product.title }}</h3>
            <span class="best-sellers__price">
              {%- if product.compare_at_price > product.price -%}
                <s class="best-sellers__compare">{{ product.compare_at_price | money }}</s>
              {%- endif -%}
              From {{ product.price | money }}
            </span>
          </div>

        </a>
      {%- else -%}
        {%- for i in (1..6) -%}
          <div class="best-sellers__item">
            <span class="best-sellers__rank">{{ i | prepend: '00' | slice: -2, 2 }}</span>
            <div class="best-sellers__image">
              <div class="best-sellers__image-fallback"></div>
            </div>
            <div class="best-sellers__info">
              <span class="best-sellers__vendor">Fragrance House</span>
              <h3 class="best-sellers__name">Signature Scent</h3>
              <span class="best-sellers__price">From $29.00</span>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Best Sellers",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Most Requested"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "The Best Sellers."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "The fragrances currently dominating TikTok. Proven compliment getters, available in discovery-sized decants."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View All Best Sellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Best Sellers"
    }
  ]
}
{% endschema %}
