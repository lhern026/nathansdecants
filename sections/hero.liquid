<section class="hero">
  <div class="hero__media">
    {%- if section.settings.image -%}
      <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.image.alt | escape }}" loading="lazy" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}">
    {%- else -%}
      <div style="width: 100%; height: 100%; background: var(--color-bg-elevated);"></div>
    {%- endif -%}
    <div class="hero__overlay"></div>
  </div>

  <div class="hero__product-image">
    {%- assign first_product = collections.all.products.first -%}
    {%- if first_product -%}
      <img src="{{ first_product.featured_image | image_url: width: 1200 }}" alt="{{ first_product.title }}" loading="lazy">
    {%- endif -%}
    <div class="hero__product-fade"></div>
  </div>
  
  <div class="hero__content reveal">
    {%- if section.settings.eyebrow != blank -%}
      <span class="hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    
    <h1 class="hero__title">{{ section.settings.title }}</h1>
    
    {%- if section.settings.subtitle != blank -%}
      <p class="hero__subtitle">{{ section.settings.subtitle }}<br>Starting at $13</p>
    {%- endif -%}

    <a href="{{ section.settings.button_link | default: '#collection' }}" class="btn btn--outline">
      <span>{{ section.settings.button_text | default: 'SHOP DECANTS' }}</span>
      <span class="btn__icon">→</span>
    </a>

    <a href="#collection" class="hero__scroll" aria-label="Scroll to collection">
      <div class="scroll-arrow"></div>
    </a>
  </div>
</section>

<div class="trust-bar">
  <div class="container">
    <div class="trust-bar__content">
      <span>100% AUTHENTIC</span>
      <span class="trust-bar__sep">·</span>
      <span>POURED BY HAND</span>
      <span class="trust-bar__sep">·</span>
      <span>SHIPS 1-3 DAYS</span>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Editorial Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Established 2024"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Nathan's Decants"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Curated decants. Poured by hand. Delivered with care."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Editorial Hero"
    }
  ]
}
{% endschema %}
