<section class="hero js-parallax-hero">
  <div class="hero__media">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, class: 'hero__video js-parallax-bg' }}
    {%- elsif section.settings.image -%}
      <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.image.alt | escape }}" loading="lazy" class="js-parallax-bg">
    {%- else -%}
      <div style="width: 100%; height: 100%; background: var(--color-bg-elevated);" class="js-parallax-bg"></div>
    {%- endif -%}
    
    <div class="hero__overlay-vignette"></div>
    <div class="hero__overlay-mesh"></div>
  </div>

  <div class="hero__product-image js-parallax-fg">
    {%- assign first_product = collections.all.products.first -%}
    {%- if first_product -%}
      <img src="{{ first_product.featured_image | image_url: width: 1200 }}" alt="{{ first_product.title }}" loading="lazy">
    {%- endif -%}
    <div class="hero__product-fade"></div>
  </div>
  
  <div class="hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <div class="hero__eyebrow-wrap reveal-cascade">
        <span class="hero__eyebrow">{{ section.settings.eyebrow }}</span>
      </div>
    {%- endif -%}
    
    <h1 class="hero__title">
      {%- if section.settings.title contains '$' -%}
        {%- assign title_parts = section.settings.title | split: ' ' -%}
        {%- for word in title_parts -%}
          <span class="hero__title-word reveal-cascade" style="transition-delay: {{ forloop.index | times: 100 }}ms">{{ word }}</span>
        {%- endfor -%}
      {%- else -%}
        {%- assign title_words = section.settings.title | split: ' ' -%}
        {%- for word in title_words -%}
          <span class="hero__title-word reveal-cascade" style="transition-delay: {{ forloop.index | times: 100 }}ms">{{ word }}</span>
        {%- endfor -%}
      {%- endif -%}
    </h1>
    
    {%- if section.settings.subtitle != blank -%}
      <p class="hero__subtitle reveal-cascade" style="transition-delay: 400ms">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    <div class="hero__actions reveal-cascade" style="transition-delay: 500ms">
      <a href="{{ section.settings.button_1_link | default: '/collections/all' }}" class="btn btn--solid">
        <span>{{ section.settings.button_1_text | default: 'BUILD YOUR SET' }}</span>
        <span class="btn__icon">→</span>
      </a>
      <a href="{{ section.settings.button_2_link | default: '/collections/all' }}" class="btn btn--outline">
        <span>{{ section.settings.button_2_text | default: 'BROWSE FRAGRANCES' }}</span>
      </a>
    </div>

    {%- comment -%} Trust Badges inside Hero {%- endcomment -%}
    <div class="hero__trust reveal-cascade" style="transition-delay: 600ms">
      <div class="hero__trust-item">
        <span class="hero__trust-icon">✨</span>
        <span class="hero__trust-label">HAND-FILLED DAILY</span>
      </div>
      <div class="hero__trust-item">
        <span class="hero__trust-icon">🏆</span>
        <span class="hero__trust-label">AUTHENTIC BOTTLES</span>
      </div>
      <div class="hero__trust-item">
        <span class="hero__trust-icon">🚚</span>
        <span class="hero__trust-label">FAST SHIPPING</span>
      </div>
    </div>
</section>

{% schema %}
{
  "name": "Conversion Hero",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Background Video"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "LUXURY FRAGRANCES. DECANTED BY HAND."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Smell like $300 for $30."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Designer & niche fragrances in discovery-sized decants. Build your rotation for less."
    },
    {
      "type": "header",
      "content": "Button 1 (Primary)"
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Text",
      "default": "BUILD YOUR SET"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Button 2 (Secondary)"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Text",
      "default": "BROWSE FRAGRANCES"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Conversion Hero"
    }
  ]
}
{% endschema %}
